%% AI Agentic System - Dual Agent Architecture
%% View this file at https://mermaid.live

graph TB
    subgraph UserInput["📥 User Input"]
        U1["Question / Query"]
        U2["Code File / Folder"]
        U3["Git Changes / PR"]
    end

    subgraph System["🎯 AI Agentic System"]
        direction TB
        
        subgraph RAGAgent["🤖 RAG Chatbot Agent - rag_main.py"]
            RA1["Agent Orchestrator"]
            
            subgraph RAGTools["🔧 RAG Tools"]
                RT1["knowledge_search"]
                RT2["clarify_question"]
                RT3["summarize_context"]
                RT4["provide_sources"]
            end
            
            subgraph RAGReflection["🔄 Self-Reflection"]
                RR1["Confidence Scoring"]
                RR2["Issue Detection"]
                RR3["Iterative Refinement"]
            end
            
            subgraph RAGEval["📊 Evaluation"]
                RE1["Relevance"]
                RE2["Groundedness"]
                RE3["Clarity"]
                RE4["Completeness"]
            end
        end
        
        subgraph CodeAgent["🔍 Code Review Agent - code_review_main.py"]
            CA1["Agent Orchestrator"]
            
            subgraph CodeTools["🔧 Code Tools"]
                CT1["file_reader"]
                CT2["static_analysis_helper"]
                CT3["markdown_writer"]
                CT4["sandbox_validator"]
            end
            
            subgraph CodeAnalysis["📊 Analysis"]
                CD1["Static Analyzer - AST + 24 Rules"]
                CD2["RAG Retriever - Best Practices"]
            end
            
            subgraph CodeReflection["🔄 Self-Reflection"]
                CR1["Review Quality Check"]
                CR2["Confidence Scoring"]
                CR3["Iterative Refinement"]
            end
            
            subgraph CodeValidation["✅ Validation"]
                CV1["Syntax Check"]
                CV2["Black Formatter"]
                CV3["Pylint Score"]
            end
        end
    end

    subgraph SharedInfra["🔗 Shared Infrastructure"]
        subgraph LLMProvider["🧠 Multi-LLM Fallback Chain"]
            L1["Gemini 2.5 Pro"]
            L2["Groq llama-3.1-8b"]
            L3["Gemini 2.5 Flash"]
            L4["OpenRouter Models"]
            L5["FLAN-T5 Local"]
        end
        
        subgraph RAGPipeline["📚 RAG Pipeline"]
            P1["PDF Loader - PyMuPDF"]
            P2["Audio Transcriber - Whisper"]
            P3["Chunker - LangChain"]
            P4["Embedder - all-MiniLM-L6-v2"]
            P5["Vector Store - ChromaDB"]
            P6["Retriever - Semantic Search"]
        end
        
        subgraph KnowledgeBase["📖 Knowledge Base - 7,124 chunks"]
            K1["22 PDF Documents"]
            K2["2 Video Transcripts"]
            K3["Data/ + Data/python/"]
        end
    end

    subgraph Output["📤 Output"]
        O1["Answer + Sources + Confidence"]
        O2["codereview.md"]
        O3["corrected_*.py"]
        O4["audit_log.json"]
    end

    %% User to Agents
    U1 --> RA1
    U2 --> CA1
    U3 --> CA1

    %% RAG Agent Flow
    RA1 --> RT1 & RT2 & RT3 & RT4
    RA1 --> RR1
    RR1 --> RR2 --> RR3
    RR3 -.->|iterate| RR1
    RA1 --> RE1 & RE2 & RE3 & RE4
    RA1 --> O1

    %% Code Agent Flow
    CA1 --> CT1 & CT2 & CT3 & CT4
    CA1 --> CD1 & CD2
    CA1 --> CR1
    CR1 --> CR2 --> CR3
    CR3 -.->|iterate| CR1
    CA1 --> CV1 --> CV2 --> CV3
    CA1 --> O2 & O3 & O4

    %% Shared Infrastructure Connections
    RT1 --> P6
    CD2 --> P6
    P6 --> P5
    P5 --> P4 --> P3
    P3 --> P1 & P2
    P1 --> K1
    P2 --> K2
    P5 --> K3

    %% LLM Fallback Chain
    RA1 --> L1
    CA1 --> L1
    L1 -.->|fallback| L2
    L2 -.->|fallback| L3
    L3 -.->|fallback| L4
    L4 -.->|fallback| L5

    %% Styling
    classDef input fill:#e1f5fe,stroke:#01579b
    classDef ragAgent fill:#e8f5e9,stroke:#1b5e20
    classDef codeAgent fill:#fff3e0,stroke:#e65100
    classDef llm fill:#f3e5f5,stroke:#4a148c
    classDef rag fill:#e0f7fa,stroke:#006064
    classDef output fill:#fce4ec,stroke:#880e4f
    
    class U1,U2,U3 input
    class RA1,RT1,RT2,RT3,RT4,RR1,RR2,RR3,RE1,RE2,RE3,RE4 ragAgent
    class CA1,CT1,CT2,CT3,CT4,CD1,CD2,CR1,CR2,CR3,CV1,CV2,CV3 codeAgent
    class L1,L2,L3,L4,L5 llm
    class P1,P2,P3,P4,P5,P6,K1,K2,K3 rag
    class O1,O2,O3,O4 output
