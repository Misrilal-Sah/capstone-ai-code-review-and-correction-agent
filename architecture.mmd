%% AI Code Review Agent - Architecture Diagram
%% View this file at https://mermaid.live

graph TB
    subgraph Input["📥 Input Layer"]
        A1[Single File]
        A2[Folder]
        A3[Git Changes]
        A4[Git Commit]
        A5[GitHub PR]
    end

    subgraph CLI["🖥️ CLI Entry Point"]
        B[code_review_main.py]
    end

    subgraph Agent["🤖 Code Review Agent"]
        C1[Agent Orchestrator<br/>agent.py]
        
        subgraph Tools["🔧 Tool Functions"]
            T1[file_reader]
            T2[static_analysis_helper]
            T3[markdown_writer]
            T4[inline_comment_generator]
            T5[sandbox_validator]
        end
        
        subgraph Analysis["📊 Analysis"]
            D1[Static Analyzer<br/>AST + 24 Rules]
            D2[RAG Retriever<br/>Best Practices]
        end
        
        subgraph LLM["🧠 LLM Provider"]
            E1[Gemini 2.5 Pro]
            E2[Groq llama-3.1-8b]
            E3[Gemini 2.5 Flash]
            E4[OpenRouter Models]
            E5[FLAN-T5 Local]
        end
        
        subgraph Reflection["🔄 Self-Reflection"]
            F1[Review Quality Check]
            F2[Confidence Scoring]
            F3[Iterative Refinement]
        end
        
        subgraph Validation["✅ Validation"]
            G1[Syntax Check]
            G2[Black Formatter]
            G3[Pylint Score]
        end
    end

    subgraph RAG["📚 RAG Pipeline"]
        H1[PDF Loader<br/>PyMuPDF]
        H2[Audio Transcriber<br/>Whisper]
        H3[Chunker<br/>LangChain]
        H4[Embedder<br/>all-MiniLM-L6-v2]
        H5[Vector Store<br/>ChromaDB]
        H6[Retriever<br/>Semantic Search]
    end

    subgraph Knowledge["📖 Knowledge Base"]
        I1[20 PDF Documents]
        I2[3 Video Transcripts]
        I3[7166 Chunks]
    end

    subgraph Output["📤 Output"]
        J1[codereview.md]
        J2[corrected_*.py]
        J3[audit_log.json]
        J4[Summary Table]
    end

    %% Connections
    A1 & A2 & A3 & A4 & A5 --> B
    B --> C1
    
    C1 --> T1 & T2 & T3 & T4 & T5
    C1 --> D1
    C1 --> D2
    
    D2 --> H6
    H6 --> H5
    H5 --> H4
    H4 --> H3
    H3 --> H1 & H2
    H1 --> I1
    H2 --> I2
    H5 --> I3
    
    C1 --> E1
    E1 -.->|fallback| E2
    E2 -.->|fallback| E3
    E3 -.->|fallback| E4
    E4 -.->|fallback| E5
    
    C1 --> F1
    F1 --> F2
    F2 --> F3
    F3 -.->|iterate| F1
    
    C1 --> G1
    G1 --> G2
    G2 --> G3
    
    C1 --> J1 & J2 & J3 & J4

    %% Styling
    classDef input fill:#e1f5fe,stroke:#01579b
    classDef agent fill:#fff3e0,stroke:#e65100
    classDef llm fill:#f3e5f5,stroke:#4a148c
    classDef rag fill:#e8f5e9,stroke:#1b5e20
    classDef output fill:#fce4ec,stroke:#880e4f
    
    class A1,A2,A3,A4,A5 input
    class C1,T1,T2,T3,T4,T5,D1,D2,F1,F2,F3,G1,G2,G3 agent
    class E1,E2,E3,E4,E5 llm
    class H1,H2,H3,H4,H5,H6,I1,I2,I3 rag
    class J1,J2,J3,J4 output
